---
import type { CollectionEntry } from "astro:content";
import { categories, tags } from "../data/taxonomy";
import SiteCard from "./SiteCard.astro";
interface Props {
  sites: CollectionEntry<"sites">[];
  heading?: string;
}
const { sites, heading = "Tools directory" } = Astro.props;
---

<section class="directory" aria-labelledby="directory-heading" data-directory>
  <div class="directory-heading section-heading">
    <div>
      <p class="eyebrow">Verified utility records</p><h2 id="directory-heading">
        {heading}
      </h2>
    </div><p class="result-count" aria-live="polite" data-result-count>
      {sites.length}
      {sites.length === 1 ? "tool" : "tools"}
    </p>
  </div>
  <div class="directory-layout">
    <form class="filter-panel" data-filters>
      <div class="field">
        <label for="tool-search">Search tools</label><input
          id="tool-search"
          name="query"
          type="search"
          placeholder="Name, purpose, or tag"
        />
      </div>
      <div class="field">
        <label for="tool-category">Category</label><select
          id="tool-category"
          name="category"
          ><option value="">All categories</option>{
            categories.map((category) => (
              <option value={category.slug}>{category.label}</option>
            ))
          }</select
        >
      </div>
      <fieldset>
        <legend>Tags</legend><div class="tag-options">
          {
            tags.map((tag) => (
              <label>
                <>
                  <input type="checkbox" name="tags" value={tag} />
                  <span>{tag}</span>
                </>
              </label>
            ))
          }
        </div>
      </fieldset>
      <button class="reset-button" type="reset">Reset filters</button>
    </form>
    <div class="directory-results">
      <div class="site-grid">
        {sites.map((site) => <SiteCard site={site} />)}
      </div><p class="empty-state" hidden data-empty-state>
        No tools match these filters.
      </p>
    </div>
  </div>
</section>
<script>
  for (const directory of document.querySelectorAll<HTMLElement>(
    "[data-directory]",
  )) {
    const form = directory.querySelector<HTMLFormElement>("[data-filters]");
    const queryInput = form?.elements.namedItem("query");
    const categorySelect = form?.elements.namedItem("category");
    const cards = [
      ...directory.querySelectorAll<HTMLElement>("[data-site-card]"),
    ];
    const count = directory.querySelector<HTMLElement>("[data-result-count]");
    const emptyState =
      directory.querySelector<HTMLElement>("[data-empty-state]");
    if (
      !(queryInput instanceof HTMLInputElement) ||
      !(categorySelect instanceof HTMLSelectElement)
    )
      continue;
    const update = () => {
      const query = queryInput.value.trim().toLowerCase();
      const category = categorySelect.value;
      const selectedTags = [
        ...(form?.querySelectorAll<HTMLInputElement>(
          'input[name="tags"]:checked',
        ) ?? []),
      ].map((input) => input.value);
      let visibleCount = 0;
      for (const card of cards) {
        const cardTags = (card.dataset.tags ?? "").split(" ");
        const visible =
          (!query || (card.dataset.search ?? "").includes(query)) &&
          (!category || card.dataset.category === category) &&
          selectedTags.every((tag) => cardTags.includes(tag));
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      }
      if (count)
        count.textContent = `${visibleCount} ${visibleCount === 1 ? "tool" : "tools"}`;
      if (emptyState) emptyState.hidden = visibleCount !== 0;
    };
    form?.addEventListener("input", update);
    form?.addEventListener("reset", () => window.setTimeout(update));
  }
</script>
