---
import type { CollectionEntry } from "astro:content";
import { categoryBySlug, faviconUrl } from "../lib/sites";
interface Props {
  site: CollectionEntry<"sites">;
}
const { site } = Astro.props;
const { name, summary, category, tags, url } = site.data;
const initial = name.charAt(0).toUpperCase();
const searchText = [
  name,
  summary,
  category,
  categoryBySlug(category)?.label,
  ...tags,
]
  .join(" ")
  .toLowerCase();
---

<article
  class="site-card"
  data-site-card
  data-category={category}
  data-tags={tags.join(" ")}
  data-search={searchText}
>
  <a
    class="site-card-detail-link"
    href={`/sites/${site.id}/`}
    aria-label={`View ${name} details`}></a>
  <div class="site-card-heading">
    <span class="favicon-tile" aria-hidden="true"
      ><img
        src={faviconUrl(url)}
        alt=""
        width="32"
        height="32"
        loading="lazy"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      /><span class="favicon-letter" style="display:none">{initial}</span></span
    ><div>
      <p class="site-card-category">{categoryBySlug(category)?.label}</p><h3>
        <a href={url} target="_blank" rel="noopener noreferrer"
          >{name}<span class="sr-only"> (opens in a new tab)</span></a
        >
      </h3>
    </div>
  </div>
  <p class="site-card-summary">{summary}</p>
  <ul class="tag-list" aria-label={`${name} tags`}>
    {tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>
