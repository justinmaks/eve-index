---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ExternalLink from "../../components/ExternalLink.astro";
import FaviconTile from "../../components/FaviconTile.astro";
import { categoryBySlug } from "../../lib/sites";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const sites = await getCollection(
    "sites",
    ({ data }) => data.status === "active",
  );
  return sites.map((site) => ({ params: { slug: site.id }, props: { site } }));
}

interface Props {
  site: CollectionEntry<"sites">;
}
const { site } = Astro.props;
const { Content } = await render(site);
const { name, url, summary, category, tags, repository } = site.data;
const categoryRecord = categoryBySlug(category);
---

<BaseLayout title={name} description={summary}>
  <article class="container detail-page">
    <a class="back-link" href={`/categories/${category}/`}
      >&#8592; {categoryRecord?.label}</a
    >
    <header class="detail-header">
      <FaviconTile
        name={name}
        url={url}
        size={48}
        class="detail-favicon"
        loading="lazy"
      />
      <div>
        <p class="eyebrow">Verified utility record</p><h1>{name}</h1><p>
          {summary}
        </p>
      </div>
    </header>
    <ul class="tag-list" aria-label={`${name} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="editorial-copy"><Content /></div>
    <div class="detail-links">
      <ExternalLink class="primary-link" href={url} label={`Visit ${name}`} />
      {
        repository && (
          <ExternalLink
            class="repository-link"
            href={repository}
            label={`Source code`}
          />
        )
      }
    </div>
  </article>
</BaseLayout>
