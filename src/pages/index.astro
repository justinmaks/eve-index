---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="EVE Index"
  description="A focused directory of EVE Online tools for capsuleers."
>
  <section id="browse" class="hero scan-grid" aria-labelledby="eve-index-title">
    <div class="container hero-copy">
      <p class="eyebrow">Capsuleer Utility Directory</p>
      <h1 id="eve-index-title">Find the right tool. Get back to space.</h1>
      <p>
        A focused, independent index of useful EVE Online tools. The directory interface is coming
        online next.
      </p>
      <p class="console-note">DIRECTORY NODE // INDEXING IN PROGRESS</p>
    </div>
  </section>
</BaseLayout>
